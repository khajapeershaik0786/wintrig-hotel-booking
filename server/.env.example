NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
JWT_SECRET=replace-with-very-long-secret
ADMIN_API_KEY=replace-with-admin-key
AUTO_MIGRATE=true

# Free LLM (recommended): get a free key at https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=
LLM_MODEL=llama-3.1-8b-instant

# Optional alternatives:
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# LLM_MODEL=gemini-2.0-flash
#
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini
#
# Or set LLM_API_KEY for whichever provider you choose.
# If no key is set, RAG falls back to free template answers.
